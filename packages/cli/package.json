{
  "name": "project-memory-runtime",
  "version": "0.1.0",
  "description": "CLI for Project Memory Runtime — evidence-backed lifecycle memory for AI coding agents",
  "license": "GPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/nicepkg/project-memory-runtime.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/nicepkg/project-memory-runtime",
  "keywords": [
    "ai", "memory", "context", "claude", "agent",
    "decisions", "evidence", "outcomes", "lifecycle"
  ],
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "project-memory-runtime": "./dist/cli.js",
    "pmr": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "assets",
    "README.md"
  ],
  "scripts": {
    "build": "pnpm --filter @slicenferqin/project-memory-runtime-core build && pnpm --filter @slicenferqin/project-memory-adapter-claude-code build && pnpm exec tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "test": "pnpm run build && node --test tests/*.test.mjs",
    "typecheck": "pnpm exec tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@slicenferqin/project-memory-runtime-core": "workspace:*",
    "@slicenferqin/project-memory-adapter-claude-code": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.6.3"
  }
}

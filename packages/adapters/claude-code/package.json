{
  "name": "@slicenfer/project-memory-adapter-claude-code",
  "version": "0.3.0",
  "description": "Claude Code adapter for Project Memory Runtime — hooks, event normalization, and session brief injection",
  "license": "GPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/nicepkg/project-memory-runtime.git",
    "directory": "packages/adapters/claude-code"
  },
  "homepage": "https://github.com/nicepkg/project-memory-runtime",
  "keywords": [
    "ai", "claude", "claude-code", "hooks", "adapter",
    "memory", "agent"
  ],
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "project-memory-claude-hook": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "pnpm exec tsc -p tsconfig.json",
    "cli": "pnpm --filter @slicenfer/project-memory-runtime-core build && pnpm run build && node ./dist/cli.js",
    "clean": "rm -rf dist",
    "test": "pnpm --filter @slicenfer/project-memory-runtime-core build && pnpm run build && node --test tests/*.test.mjs",
    "typecheck": "pnpm exec tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@slicenfer/project-memory-runtime-core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.6.3"
  }
}

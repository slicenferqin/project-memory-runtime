{
  "name": "@slicenferqin/project-memory-adapter-claude-code",
  "version": "0.0.0",
  "private": true,
  "description": "Reference Claude Code adapter spike for Project Memory Runtime",
  "license": "GPL-3.0-only",
  "engines": {
    "node": ">=20 <21"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "pnpm exec tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "test": "pnpm --filter @slicenferqin/project-memory-runtime-core build && pnpm run build && node --test tests/*.test.mjs",
    "typecheck": "pnpm exec tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@slicenferqin/project-memory-runtime-core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.6.3"
  }
}

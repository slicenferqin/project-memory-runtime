{
  "name": "@slicenfer/project-memory-runtime-core",
  "version": "0.3.0",
  "description": "Core runtime for Project Memory Runtime — evidence-backed lifecycle memory for AI coding agents",
  "license": "GPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/nicepkg/project-memory-runtime.git",
    "directory": "packages/runtime"
  },
  "homepage": "https://github.com/nicepkg/project-memory-runtime",
  "keywords": [
    "ai", "memory", "runtime", "sqlite", "evidence",
    "claims", "outcomes", "lifecycle"
  ],
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "pnpm exec tsc -p tsconfig.json && node ./scripts/copy-sql-assets.mjs",
    "clean": "rm -rf dist",
    "test": "pnpm run build && node --test tests/runtime-smoke.test.mjs tests/outcome-visualization.test.mjs tests/activation-engine.test.mjs tests/contracts.test.mjs",
    "typecheck": "pnpm exec tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "better-sqlite3": "^11.10.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.10.2",
    "typescript": "^5.6.3"
  }
}
